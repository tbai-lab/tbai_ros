Panels:
  - Class: rviz/Displays
    Help Height: 87
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Grid1
        - /RobotModel1
        - /GridMap1
        - /MarkerArray1
        - /MarkerArray2
      Splitter Ratio: 0.5
    Tree Height: 436
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: Image
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 0.5
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 500
      Reference Frame: <Fixed Frame>
      Value: true
    - Alpha: 1
      Class: rviz/RobotModel
      Collision Enabled: false
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
        LF_FOOT:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        LH_FOOT:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        Link Tree Style: Links in Alphabetic Order
        RF_FOOT:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        RH_FOOT:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        base:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        base_inertia:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link_back:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link_front_left:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link_front_right:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link_left:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_link_right:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical_back:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical_front_left:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical_front_right:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical_left:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        camera_optical_right:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        fl_hip:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        fl_lleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        fl_uleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        fr_hip:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        fr_lleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        fr_uleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hl_hip:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hl_lleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hl_uleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hr_hip:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hr_lleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        hr_uleg:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
      Name: RobotModel
      Robot Description: robot_description
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Class: grid_map_rviz_plugin/GridMap
      Color: 156; 156; 156
      Color Layer: elevation
      Color Transformer: FlatColor
      ColorMap: default
      Enabled: true
      Grid Cell Decimation: 1
      Grid Line Thickness: 0.10000000149011612
      Height Layer: elevation
      Height Transformer: GridMapLayer
      History Length: 1
      Invert ColorMap: false
      Max Color: 255; 255; 255
      Max Intensity: 10
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: GridMap
      Show Grid Lines: true
      Topic: /convex_plane_decomposition_ros/filtered_map
      Unreliable: false
      Use ColorMap: true
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /contact_points
      Name: MarkerArray
      Namespaces:
        "": true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /ocs2_quadruped/optimizedStateTrajectory
      Name: MarkerArray
      Namespaces:
        Base Trajectory: true
        EE Trajectories: true
        Future footholds: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /ocs2_quadruped/swing_planner/trajectory_LH
      Name: MarkerArray
      Namespaces:
        "": true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /ocs2_quadruped/swing_planner/trajectory_RF
      Name: MarkerArray
      Namespaces:
        "": true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /ocs2_quadruped/swing_planner/trajectory_RH
      Name: MarkerArray
      Namespaces:
        "": true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /ocs2_quadruped/desiredVelTrajectory
      Name: MarkerArray
      Namespaces:
        "": true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /convex_plane_decomposition_ros/boundaries
      Name: MarkerArray
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Image
      Enabled: true
      Image Topic: /camera/front/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: true
  Enabled: true
  Global Options:
    Background Color: 255; 255; 255
    Default Light: true
    Fixed Frame: odom
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 10.509790420532227
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Field of View: 0.7853981852531433
      Focal Point:
        X: -2.512227773666382
        Y: 2.3268237113952637
        Z: -2.1162967681884766
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.5003988146781921
      Target Frame: base
      Yaw: 5.536747455596924
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 1371
  Hide Left Dock: false
  Hide Right Dock: false
  Image:
    collapsed: false
  QMainWindow State: 
