<?xml version="1.0" encoding="utf-8"?>
<launch>
    <!-- Required arguments -->
    <arg name="robot_name"          default="go2"/>
    <arg name="tbai_config_path"    default="$(find tbai_ros_mpc)/config/go2/perceptive/default_config.yaml"/>

    <arg name="sqp_settings_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/sqp.info"/>
    <arg name="frame_declaration_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/frame_declarations.info"/>
    <arg name="task_settings_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/task.info"/>
    <arg name="target_command_config_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/targetCommand.info"/>
    <arg name="controller_config_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/controllers.info"/>
    <arg name="gait_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/gait.info"/>

    <!-- Set environment variable for config path -->
    <env name="TBAI_GLOBAL_CONFIG_PATH" value="$(arg tbai_config_path)"/>

    <!-- Launch virtual joystick -->
    <node name="virtual_joystick" pkg="tbai_ros_utils" type="virtual_joystick.py" output="screen"/>

    <!-- Upload config path to ROS param server -->
    <param name="tbai_config_path" type="string" value="$(arg tbai_config_path)"/>
    <param name="sqp_settings_file" type="string" value="$(arg sqp_settings_file)"/>
    <param name="frame_declaration_file" type="string" value="$(arg frame_declaration_file)"/>
    <param name="task_settings_file" type="string" value="$(arg task_settings_file)"/>
    <param name="target_command_config_file" type="string" value="$(arg target_command_config_file)"/>
    <param name="controller_config_file" type="string" value="$(arg controller_config_file)"/>
    <param name="robot_name" type="string" value="$(arg robot_name)"/>
    <param name="gait_file" type="string" value="$(arg gait_file)"/>

    <node pkg="tbai_ros_mpc" type="quadruped_mpc_node" name="quadruped_mpc_node" output="screen"/>

    <!-- Launch Gait command node -->
    <node pkg="tbai_ros_ocs2" type="gait_command_node" name="gait_command_node"
          output="screen" launch-prefix="x-terminal-emulator -e">
        <param name="robot_name" value="$(arg robot_name)"/>
    </node>

    <!-- Start Rviz visualizer -->
    <arg name="rvizconfig" default="$(find tbai_ros_mpc)/launch/rviz/robot.rviz" />
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(arg rvizconfig)" output="screen" />

    <!-- Launch convex decomposition node -->
        <include file="$(find convex_plane_decomposition_ros)/launch/convex_plane_decomposition.launch">
          <arg name="parameter_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/convex_plane_decomposition_parameters.yaml"/>
          <arg name="node_parameter_file" default="$(find tbai_ros_mpc)/config/go2/perceptive/convex_plane_decomposition_node.yaml"/>
        </include>

        <!-- Elevation mapping -->
        <node pkg="nodelet" type="nodelet" name="pcl_manager" args="manager" output="screen"/>
        <!-- Front camera -->
        <node pkg="nodelet" type="nodelet" name="voxel_grid" args="load pcl/VoxelGrid pcl_manager" output="screen">
      <remap from="~input" to="/camera/depth/points"/>
        <remap from="~output" to="/camera/depth/points_downsampled"/>
        <rosparam>
            filter_field_name: z
            filter_limit_min: 0.01
            filter_limit_max: 4.0  <!-- Limit the range of points to forward to 6 meters in viewing direction-->
            filter_limit_negative: False
            leaf_size: 0.06  <!-- Limit the density to 5 cm-->
        </rosparam>
        </node>
        <!-- Rear camera -->
        <node pkg="nodelet" type="nodelet" name="voxel_grid1" args="load pcl/VoxelGrid pcl_manager" output="screen">
      <remap from="~input" to="/rear_camera/depth/points"/>
        <remap from="~output" to="/rear_camera/depth/points_downsampled"/>
        <rosparam>
            filter_field_name: z
            filter_limit_min: 0.01
            filter_limit_max: 4.0  <!-- Limit the range of points to forward to 6 meters in viewing direction-->
            filter_limit_negative: False
            leaf_size: 0.06  <!-- Limit the density to 5 cm-->
        </rosparam>
        </node>

        <!-- Right camera -->
        <node pkg="nodelet" type="nodelet" name="voxel_grid2" args="load pcl/VoxelGrid pcl_manager" output="screen">
      <remap from="~input" to="/right_camera/depth/points"/>
        <remap from="~output" to="/right_camera/depth/points_downsampled"/>
        <rosparam>
            filter_field_name: z
            filter_limit_min: 0.01
            filter_limit_max: 4.0  <!-- Limit the range of points to forward to 6 meters in viewing direction-->
            filter_limit_negative: False
            leaf_size: 0.06  <!-- Limit the density to 5 cm-->
        </rosparam>
        </node>

        <!-- Left camera -->
        <node pkg="nodelet" type="nodelet" name="voxel_grid3" args="load pcl/VoxelGrid pcl_manager" output="screen">
      <remap from="~input" to="/left_camera/depth/points"/>
        <remap from="~output" to="/left_camera/depth/points_downsampled"/>
        <rosparam>
            filter_field_name: z
            filter_limit_min: 0.01
            filter_limit_max: 4.0  <!-- Limit the range of points to forward to 6 meters in viewing direction-->
            filter_limit_negative: False
            leaf_size: 0.06  <!-- Limit the density to 5 cm-->
        </rosparam>
        </node>

        <node pkg="elevation_mapping" type="elevation_mapping" name="elevation_mapping" output="screen">
        <rosparam command="load" file="$(find tbai_ros_mpc)/config/go2/perceptive/elevation_mapping.yaml"/>
        </node>

</launch>
